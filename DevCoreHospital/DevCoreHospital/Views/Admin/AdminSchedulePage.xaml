<Page
    x:Class="DevCoreHospital.Views.Admin.AdminSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DevCoreHospital.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <Grid Padding="24" ColumnSpacing="20" Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource CardBrush}" 
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
                CornerRadius="12" Padding="20" VerticalAlignment="Top">
            <StackPanel Spacing="20">
                <TextBlock Text="Shift Roster" Foreground="{StaticResource TextBrush}" 
                           FontSize="24" FontWeight="SemiBold"/>

                <TextBlock Text="View Mode" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,-15"/>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="DailyBtn" Content="Daily" Grid.Column="0" HorizontalAlignment="Stretch" 
                                  IsChecked="True" Click="ViewMode_Click"/>
                    <ToggleButton x:Name="WeeklyBtn" Content="Weekly" Grid.Column="1" HorizontalAlignment="Stretch" 
                                  Click="ViewMode_Click"/>
                </Grid>

                <TextBlock Text="Select Department" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,10,0,-15"/>
                <ComboBox x:Name="DepartmentFilterComboBox" 
                          PlaceholderText="All Departments" HorizontalAlignment="Stretch"
                          Foreground="{StaticResource TextBrush}"
                          SelectionChanged="DepartmentFilterComboBox_SelectionChanged"
                          SelectedIndex="0">
                    <x:String>All Departments</x:String>
                    <x:String>ER</x:String>
                    <x:String>Cardiology</x:String>
                    <x:String>Central Pharmacy</x:String>
                    <x:String>Neurology</x:String>
                </ComboBox>

                <TextBlock Text="Select Anchor Date" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,10,0,-15"/>
                <CalendarView x:Name="DateCalendar" 
                              SelectionMode="Single"
                              SelectedDatesChanged="DateCalendar_SelectedDatesChanged"
                              HorizontalAlignment="Stretch"
                              Foreground="{StaticResource TextBrush}"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource CardBrush}" 
              BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
              CornerRadius="12" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.ScheduleTitle, Mode=OneWay}" 
                       Foreground="{StaticResource TextBrush}" 
                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Shifts, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Shift">
                        <Grid Padding="15" Margin="0,0,0,10" Background="#1A241C" CornerRadius="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" BorderBrush="#2E3B32" BorderThickness="0,0,1,0" Padding="0,0,15,0">
                                    <TextBlock Text="{x:Bind DisplayDayMonth}" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind DisplayDayName}" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center" Margin="15,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="{x:Bind AppointedStaff.FirstName}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" FontSize="16"/>
                                        <TextBlock Text="{x:Bind AppointedStaff.LastName}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" FontSize="16"/>
                                        
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <SymbolIcon Symbol="Map" Foreground="{StaticResource MutedBrush}" Width="12" Height="12"/>
                                        <TextBlock Text="{x:Bind Location}" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                                        <TextBlock Text="{x:Bind DisplayStartTime}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="-" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{x:Bind DisplayEndTime}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Status}" Foreground="#4CAF50" HorizontalAlignment="Right" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                <Button Content="Set Active" Click="SetActive_Click" Tag="{x:Bind Id}" Background="#2E7D32" Foreground="White"/>
                                <Button Content="Cancel" Click="CancelShift_Click" Tag="{x:Bind Id}" Background="#C62828" Foreground="White"/>
                                <Button Content="Auto-Reassign" Click="AutoReassign_Click" Tag="{x:Bind}" Background="#0277BD" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>