<Page
    x:Class="DevCoreHospital.Views.ShiftSwapPlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>

        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <ScrollViewer Background="{StaticResource BgBrush}">
        <Grid Padding="24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Automated Fatigue Management &amp; Shift Balancing"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="36"
                       FontWeight="SemiBold"/>

            <Grid Grid.Row="1" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DatePicker Grid.Column="0"
                            Date="{Binding SelectedWeekStart, Mode=TwoWay}"
                            MinWidth="320"
                            HorizontalAlignment="Stretch"/>

                <Button Grid.Column="1"
                        Content="Run Auto-Audit"
                        Command="{Binding RunAutoAuditCommand}"
                        Click="RunAutoAudit_Click"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderBrush="{StaticResource AccentBrush}"/>

                <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WeekLabel}" Foreground="{StaticResource TextBrush}" FontSize="16"/>
                    <TextBlock Text="{Binding PublishStatus}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="#332A1204"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="#FFB91C1C"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Conflicts (red highlights block publishing)"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding Violations}" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFEF4444" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Staff}" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Window}" Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock Text="{Binding Rule}" Foreground="#FFFFB4B4"/>
                                        <TextBlock Text="{Binding Message}" Foreground="#FFFFB4B4" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Auto-Suggest replacements"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding Suggestions}" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ReassignText}" Foreground="{StaticResource TextBrush}" FontSize="16"/>
                                        <TextBlock Text="{Binding Reason}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>