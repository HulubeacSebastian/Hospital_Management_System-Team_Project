<Page
    x:Class="DevCoreHospital.Views.Pharmacy.PharmacySchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:DevCoreHospital.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

        <SolidColorBrush x:Key="BgBrush" Color="#FF0B120D"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF0F1711"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FFB7C2BA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF166534"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="14" Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Pharmacy Schedule"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="44"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding HeaderSubtitle}"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="16"/>
            </StackPanel>

            <ComboBox Grid.Column="1"
                      Height="40"
                      ItemsSource="{Binding Pharmacists}"
                      SelectedItem="{Binding SelectedPharmacist, Mode=TwoWay}"
                      DisplayMemberPath="PharmacistName"
                      PlaceholderText="Select pharmacist"/>
        </Grid>

        <!-- Controls (navigation + view mode) -->
        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Previous" Command="{Binding PreviousPeriodCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>
            <Button Grid.Column="1" Content="Today" Command="{Binding TodayCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>
            <Button Grid.Column="2" Content="Next" Command="{Binding NextPeriodCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>

            <Button x:Name="DateButton"
                    Grid.Column="3"
                    Content="{Binding SelectedDateText}"
                    Margin="8,0,0,0"
                    Background="Transparent"
                    Foreground="{StaticResource TextBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    Padding="12,6">
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <CalendarView x:Name="DateCalendar"
                                      SelectionMode="Single"
                                      SelectedDatesChanged="DateCalendar_SelectedDatesChanged"/>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button Grid.Column="4" Content="Daily" Command="{Binding ShowDailyCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    Margin="8,0,0,0"/>
            <Button Grid.Column="5" Content="Weekly" Command="{Binding ShowWeeklyCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>
            <Button Grid.Column="6" Content="Refresh" Command="{Binding RefreshCommand}"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{StaticResource AccentBrush}"/>
        </Grid>

        <!-- Error / access messages -->
        <StackPanel Grid.Row="2" Spacing="10">
            <Border Background="#332A1204"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    Visibility="{Binding IsAccessDenied, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock TextWrapping="Wrap"
                           Foreground="#FFFFB4B4"
                           Text="Pharmacy Schedule is available to pharmacist accounts. Set Role to Pharmacist in CurrentUserService (or MockCurrentUserService) to view your roster."/>
            </Border>

            <Border Background="#332A1204"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FFFFB4B4"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Content: empty state + schedule list -->
        <Grid Grid.Row="3">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="No shifts in this period."
                           Foreground="{StaticResource TextBrush}"
                           FontSize="20"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Try Previous/Next, change the period, or Refresh."
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ListView ItemsSource="{Binding Shifts}"
                      SelectionMode="None"
                      Background="Transparent"
                      BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <Grid RowSpacing="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding RotationAssignment}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>

                                    <Border Grid.Column="1"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding TimeRangeDetail}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding DayLabel}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="13"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Loading overlay -->
            <Grid Background="#66000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <ProgressRing IsActive="True" Width="56" Height="56"/>
                    <TextBlock Text="Loading pharmacy roster..."
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
